# ── SoundOn Copyright Alert Bot — environment variables ──────────────────────
# Copy this file to `.env` and fill in the real values. `.env` is gitignored
# and must NEVER be committed. Load it into your shell before running the bot,
# e.g.  `set -a; . ./.env; set +a`

# ── Lark bot app credentials (REQUIRED) ──────────────────────────────────────
# App secret for the copyright bot (Lark custom app cli_aa94690b12b81cde).
# The code reads BOT_SECRET first, then falls back to LARK_APP_SECRET.
BOT_SECRET=
LARK_APP_SECRET=

# ── External AIME/Feishu tool locations (REQUIRED in production) ──────────────
# Absolute path to the AIME `inner_skills` directory that provides the
# `feishu-im-send` and `aeolus-platform-analysis` helper scripts. If unset, the
# bot looks for an `inner_skills/` folder next to the repo root.
INNER_SKILLS_DIR=/path/to/inner_skills

# Optional: full path to the Aeolus dataset SQL query script. If unset it is
# derived from INNER_SKILLS_DIR.
# AEOLUS_SCRIPT=/path/to/inner_skills/aeolus-platform-analysis/scripts/dataset_sql_query.py
